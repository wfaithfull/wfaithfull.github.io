---
// Standalone presentation — not linked from site navigation
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex, nofollow" />
        <title>UAP Physics Primer — Due Diligence Vol I</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
        <script>
            (function() {
                var HASH = 'a762613c5b228e428aeb88eba5fd972044006f725401cf55cacb4ed9161b3fce';
                if (sessionStorage.getItem('deck-auth') === HASH) return;
                document.documentElement.style.display = 'none';
                async function sha256(s) {
                    var buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
                    return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
                }
                async function gate() {
                    while (true) {
                        var p = prompt('This deck is password protected.\nPlease enter the password:');
                        if (p === null) return;
                        if (await sha256(p) === HASH) {
                            sessionStorage.setItem('deck-auth', HASH);
                            document.documentElement.style.display = '';
                            return;
                        }
                        alert('Incorrect password.');
                    }
                }
                gate();
            })();
        </script>
        <style>
            /* ===== Reset & Base ===== */
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            html,
            body {
                height: 100%;
                overflow: hidden;
            }
            body {
                font-family: "Inter", system-ui, sans-serif;
                background: #07070e;
                color: #e8e8f0;
                -webkit-font-smoothing: antialiased;
            }

            /* ===== Deck Layout ===== */
            #deck {
                width: 100vw;
                height: 100vh;
                position: relative;
            }

            .slide {
                position: absolute;
                inset: 0;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 4vh 6vw;
                opacity: 0;
                visibility: hidden;
                transition:
                    opacity 0.5s ease,
                    visibility 0.5s ease;
                overflow: hidden;
            }

            .slide.active {
                opacity: 1;
                visibility: visible;
            }

            /* Slide content fades in */
            .slide .content {
                opacity: 0;
                transform: translateY(20px);
                transition:
                    opacity 0.6s ease 0.2s,
                    transform 0.6s ease 0.2s;
                width: 100%;
                max-width: 1100px;
                text-align: center;
            }
            .slide.active .content {
                opacity: 1;
                transform: translateY(0);
            }

            /* ===== Typography ===== */
            h1 {
                font-size: clamp(2rem, 5vw, 4rem);
                font-weight: 700;
                line-height: 1.1;
                color: #ffffff;
                margin-bottom: 0.5em;
            }
            h2 {
                font-size: clamp(1.6rem, 3.5vw, 2.8rem);
                font-weight: 600;
                line-height: 1.2;
                color: #ffffff;
                margin-bottom: 0.6em;
            }
            h3 {
                font-size: clamp(1.1rem, 2vw, 1.5rem);
                font-weight: 500;
                color: #a0a0b8;
                margin-bottom: 1em;
            }
            p,
            li {
                font-size: clamp(1rem, 1.8vw, 1.35rem);
                line-height: 1.6;
                color: #c0c0d0;
            }
            .mono {
                font-family: "JetBrains Mono", monospace;
            }
            .accent {
                color: #38bdf8;
            }
            .amber {
                color: #f59e0b;
            }
            .green {
                color: #34d399;
            }
            .purple {
                color: #a78bfa;
            }
            .red {
                color: #ef4444;
            }
            .dim {
                color: #6b7280;
            }
            .small {
                font-size: clamp(0.8rem, 1.2vw, 1rem);
            }
            .large {
                font-size: clamp(1.4rem, 2.5vw, 2rem);
            }
            .formula {
                font-family: "JetBrains Mono", monospace;
                font-size: clamp(1.2rem, 2vw, 1.6rem);
                color: #38bdf8;
                background: rgba(56, 189, 248, 0.08);
                padding: 0.4em 0.8em;
                border-radius: 8px;
                display: inline-block;
                margin: 0.5em 0;
                border: 1px solid rgba(56, 189, 248, 0.15);
            }

            /* ===== Controls ===== */
            .progress-bar {
                position: fixed;
                bottom: 0;
                left: 0;
                height: 3px;
                background: #38bdf8;
                transition: width 0.4s ease;
                z-index: 100;
            }
            .slide-counter {
                position: fixed;
                bottom: 12px;
                right: 20px;
                font-size: 0.85rem;
                color: #4a4a60;
                font-family: "JetBrains Mono", monospace;
                z-index: 100;
            }
            .nav-hint {
                position: fixed;
                bottom: 12px;
                left: 20px;
                font-size: 0.8rem;
                color: #3a3a50;
                z-index: 100;
                transition: opacity 0.5s ease;
            }

            /* ===== Slide Backgrounds ===== */
            .slide::before {
                content: "";
                position: absolute;
                inset: 0;
                z-index: -1;
            }
            #slide-title::before {
                background: radial-gradient(
                    ellipse at 50% 40%,
                    rgba(56, 189, 248, 0.06) 0%,
                    transparent 70%
                );
            }
            #slide-plasma::before,
            #slide-cold-plasma::before {
                background: radial-gradient(
                    ellipse at 50% 50%,
                    rgba(167, 139, 250, 0.05) 0%,
                    transparent 70%
                );
            }
            #slide-ionization::before,
            #slide-energy::before {
                background: radial-gradient(
                    ellipse at 50% 50%,
                    rgba(245, 158, 11, 0.04) 0%,
                    transparent 70%
                );
            }
            #slide-separation::before,
            #slide-larmor::before {
                background: radial-gradient(
                    ellipse at 50% 50%,
                    rgba(56, 189, 248, 0.05) 0%,
                    transparent 70%
                );
            }

            /* ===== Component: Atmosphere Bars ===== */
            .atmos-bars {
                display: flex;
                flex-direction: column;
                gap: 12px;
                margin: 2em auto;
                max-width: 700px;
            }
            .atmos-row {
                display: grid;
                grid-template-columns: 80px 1fr 100px;
                align-items: center;
                gap: 12px;
            }
            .atmos-label {
                text-align: right;
                font-weight: 500;
                font-size: clamp(0.85rem, 1.3vw, 1.1rem);
            }
            .atmos-track {
                height: 28px;
                background: rgba(255, 255, 255, 0.04);
                border-radius: 4px;
                overflow: hidden;
                position: relative;
            }
            .atmos-fill {
                height: 100%;
                border-radius: 4px;
                width: 0;
                transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
            }
            .slide.active .atmos-fill {
                width: var(--w);
            }
            .atmos-value {
                font-family: "JetBrains Mono", monospace;
                font-size: clamp(0.75rem, 1.1vw, 0.95rem);
                color: #8888a0;
            }

            /* ===== Component: State Boxes ===== */
            .states-row {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: clamp(1rem, 3vw, 3rem);
                margin: 2em 0;
                flex-wrap: wrap;
            }
            .state-box {
                width: clamp(120px, 18vw, 180px);
                height: clamp(120px, 18vw, 180px);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 12px;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 12px;
                position: relative;
                overflow: hidden;
                background: rgba(255, 255, 255, 0.02);
            }
            .state-box.plasma-box {
                border-color: rgba(167, 139, 250, 0.3);
                background: rgba(167, 139, 250, 0.05);
            }
            .state-label {
                font-size: clamp(0.75rem, 1.2vw, 0.95rem);
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.08em;
            }
            .state-arrow {
                font-size: 1.5rem;
                color: #4a4a60;
            }
            .state-particles {
                width: 60px;
                height: 60px;
                position: relative;
            }

            /* Solid: grid */
            .p-solid .dot {
                position: absolute;
                width: 8px;
                height: 8px;
                background: #60a5fa;
                border-radius: 50%;
            }
            .p-solid .dot:nth-child(1) {
                top: 4px;
                left: 4px;
            }
            .p-solid .dot:nth-child(2) {
                top: 4px;
                left: 22px;
            }
            .p-solid .dot:nth-child(3) {
                top: 4px;
                left: 40px;
            }
            .p-solid .dot:nth-child(4) {
                top: 22px;
                left: 4px;
            }
            .p-solid .dot:nth-child(5) {
                top: 22px;
                left: 22px;
            }
            .p-solid .dot:nth-child(6) {
                top: 22px;
                left: 40px;
            }
            .p-solid .dot:nth-child(7) {
                top: 40px;
                left: 4px;
            }
            .p-solid .dot:nth-child(8) {
                top: 40px;
                left: 22px;
            }
            .p-solid .dot:nth-child(9) {
                top: 40px;
                left: 40px;
            }

            /* Liquid: jiggle */
            .p-liquid .dot {
                position: absolute;
                width: 8px;
                height: 8px;
                background: #60a5fa;
                border-radius: 50%;
            }
            .p-liquid .dot:nth-child(1) {
                top: 8px;
                left: 10px;
                animation: jiggle 1.5s ease-in-out infinite;
            }
            .p-liquid .dot:nth-child(2) {
                top: 6px;
                left: 28px;
                animation: jiggle 1.8s ease-in-out infinite 0.2s;
            }
            .p-liquid .dot:nth-child(3) {
                top: 12px;
                left: 44px;
                animation: jiggle 1.4s ease-in-out infinite 0.4s;
            }
            .p-liquid .dot:nth-child(4) {
                top: 24px;
                left: 6px;
                animation: jiggle 1.6s ease-in-out infinite 0.1s;
            }
            .p-liquid .dot:nth-child(5) {
                top: 26px;
                left: 24px;
                animation: jiggle 1.7s ease-in-out infinite 0.3s;
            }
            .p-liquid .dot:nth-child(6) {
                top: 22px;
                left: 42px;
                animation: jiggle 1.3s ease-in-out infinite 0.5s;
            }
            .p-liquid .dot:nth-child(7) {
                top: 40px;
                left: 12px;
                animation: jiggle 1.5s ease-in-out infinite 0.6s;
            }
            .p-liquid .dot:nth-child(8) {
                top: 42px;
                left: 30px;
                animation: jiggle 1.9s ease-in-out infinite 0.15s;
            }
            .p-liquid .dot:nth-child(9) {
                top: 38px;
                left: 46px;
                animation: jiggle 1.4s ease-in-out infinite 0.35s;
            }

            /* Gas: float around */
            .p-gas .dot {
                position: absolute;
                width: 8px;
                height: 8px;
                background: #60a5fa;
                border-radius: 50%;
            }
            .p-gas .dot:nth-child(1) {
                animation: gas-float-1 3s ease-in-out infinite;
            }
            .p-gas .dot:nth-child(2) {
                animation: gas-float-2 3.5s ease-in-out infinite 0.3s;
            }
            .p-gas .dot:nth-child(3) {
                animation: gas-float-3 2.8s ease-in-out infinite 0.6s;
            }
            .p-gas .dot:nth-child(4) {
                animation: gas-float-4 3.2s ease-in-out infinite 0.2s;
            }
            .p-gas .dot:nth-child(5) {
                animation: gas-float-5 3.6s ease-in-out infinite 0.5s;
            }
            .p-gas .dot:nth-child(6) {
                animation: gas-float-1 2.9s ease-in-out infinite 0.8s;
            }
            .p-gas .dot:nth-child(7) {
                animation: gas-float-3 3.1s ease-in-out infinite 0.1s;
            }
            .p-gas .dot:nth-child(8) {
                animation: gas-float-2 3.3s ease-in-out infinite 0.7s;
            }
            .p-gas .dot:nth-child(9) {
                animation: gas-float-4 2.7s ease-in-out infinite 0.4s;
            }

            /* Plasma: atoms + free electrons */
            .p-plasma .ion {
                position: absolute;
                width: 10px;
                height: 10px;
                background: #a78bfa;
                border-radius: 50%;
                box-shadow: 0 0 6px rgba(167, 139, 250, 0.5);
            }
            .p-plasma .electron {
                position: absolute;
                width: 4px;
                height: 4px;
                background: #38bdf8;
                border-radius: 50%;
                box-shadow: 0 0 4px rgba(56, 189, 248, 0.6);
            }
            .p-plasma .ion:nth-child(1) {
                top: 10px;
                left: 14px;
                animation: jiggle 1.2s ease-in-out infinite;
            }
            .p-plasma .ion:nth-child(2) {
                top: 30px;
                left: 36px;
                animation: jiggle 1.5s ease-in-out infinite 0.3s;
            }
            .p-plasma .ion:nth-child(3) {
                top: 42px;
                left: 12px;
                animation: jiggle 1.3s ease-in-out infinite 0.6s;
            }
            .p-plasma .ion:nth-child(4) {
                top: 14px;
                left: 42px;
                animation: jiggle 1.4s ease-in-out infinite 0.15s;
            }
            .p-plasma .electron:nth-child(5) {
                animation: electron-zip-1 1s linear infinite;
            }
            .p-plasma .electron:nth-child(6) {
                animation: electron-zip-2 0.8s linear infinite 0.2s;
            }
            .p-plasma .electron:nth-child(7) {
                animation: electron-zip-3 1.1s linear infinite 0.5s;
            }
            .p-plasma .electron:nth-child(8) {
                animation: electron-zip-1 0.9s linear infinite 0.7s;
            }
            .p-plasma .electron:nth-child(9) {
                animation: electron-zip-2 1.2s linear infinite 0.4s;
            }

            /* ===== Component: Two-Temperature Visual ===== */
            .two-temp {
                position: relative;
                width: min(600px, 80vw);
                height: 260px;
                margin: 2em auto;
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 16px;
                background: rgba(255, 255, 255, 0.02);
                overflow: hidden;
            }
            .two-temp .big-atom {
                position: absolute;
                width: 24px;
                height: 24px;
                background: rgba(107, 114, 128, 0.6);
                border-radius: 50%;
                border: 1px solid rgba(107, 114, 128, 0.3);
            }
            .two-temp .fast-electron {
                position: absolute;
                width: 5px;
                height: 5px;
                background: #f59e0b;
                border-radius: 50%;
                box-shadow: 0 0 8px rgba(245, 158, 11, 0.6);
            }
            .temp-label {
                position: absolute;
                padding: 6px 14px;
                border-radius: 20px;
                font-size: clamp(0.7rem, 1.1vw, 0.9rem);
                font-weight: 600;
                font-family: "JetBrains Mono", monospace;
            }
            .temp-label.gas-temp {
                bottom: 16px;
                left: 16px;
                background: rgba(107, 114, 128, 0.15);
                color: #9ca3af;
                border: 1px solid rgba(107, 114, 128, 0.2);
            }
            .temp-label.electron-temp {
                top: 16px;
                right: 16px;
                background: rgba(245, 158, 11, 0.12);
                color: #f59e0b;
                border: 1px solid rgba(245, 158, 11, 0.2);
            }

            /* ===== Component: Ionization Animation ===== */
            .ionization-scene {
                position: relative;
                width: min(650px, 85vw);
                height: 220px;
                margin: 1.5em auto;
            }
            .scene-atom {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                width: 60px;
                height: 60px;
            }
            .nucleus {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                width: 24px;
                height: 24px;
                background: #6b7280;
                border-radius: 50%;
                z-index: 2;
            }
            .orbit-ring {
                position: absolute;
                top: 50%;
                left: 50%;
                width: 54px;
                height: 54px;
                transform: translate(-50%, -50%);
                border: 1px dashed rgba(255, 255, 255, 0.1);
                border-radius: 50%;
            }
            .bound-electron {
                position: absolute;
                width: 8px;
                height: 8px;
                background: #60a5fa;
                border-radius: 50%;
                box-shadow: 0 0 6px rgba(96, 165, 250, 0.5);
                top: -4px;
                left: 50%;
                transform: translateX(-50%);
            }
            .orbit-ring {
                animation: orbit 2s linear infinite;
            }
            .slide.active .bound-electron {
                animation: bound-vanish 0.1s ease 1.5s forwards;
            }
            .slide.active .orbit-ring {
                animation:
                    orbit 2s linear infinite,
                    orbit-fade 0.3s ease 1.5s forwards;
            }
            .incoming-electron {
                position: absolute;
                top: 50%;
                left: -40px;
                transform: translateY(-50%);
                width: 8px;
                height: 8px;
                background: #f59e0b;
                border-radius: 50%;
                box-shadow: 0 0 10px rgba(245, 158, 11, 0.7);
            }
            .slide.active .incoming-electron {
                animation:
                    approach 1.5s ease-in forwards,
                    collide-flash 0.15s ease 1.5s forwards;
            }
            .ejected-electron {
                position: absolute;
                top: 50%;
                left: 50%;
                width: 8px;
                height: 8px;
                background: #60a5fa;
                border-radius: 50%;
                box-shadow: 0 0 8px rgba(96, 165, 250, 0.6);
                opacity: 0;
            }
            .slide.active .ejected-electron {
                animation: eject 1.2s ease-out 1.6s forwards;
            }
            .collision-flash {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                width: 40px;
                height: 40px;
                background: radial-gradient(
                    circle,
                    rgba(245, 158, 11, 0.4),
                    transparent 70%
                );
                border-radius: 50%;
                opacity: 0;
            }
            .slide.active .collision-flash {
                animation: flash-burst 0.5s ease 1.5s;
            }
            .plus-charge {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                font-weight: 700;
                font-size: 1.2rem;
                color: #ef4444;
                opacity: 0;
            }
            .slide.active .plus-charge {
                animation: appear 0.4s ease 2.2s forwards;
            }
            .scene-label {
                position: absolute;
                bottom: -4px;
                font-size: clamp(0.7rem, 1vw, 0.85rem);
                color: #6b7280;
                width: 100%;
                text-align: center;
            }

            /* ===== Component: Energy Bars ===== */
            .energy-bars {
                display: flex;
                flex-direction: column;
                gap: 10px;
                margin: 1.5em auto;
                max-width: 750px;
            }
            .energy-row {
                display: grid;
                grid-template-columns: 50px 1fr 75px;
                align-items: center;
                gap: 10px;
            }
            .energy-name {
                text-align: right;
                font-weight: 600;
                font-size: clamp(0.8rem, 1.2vw, 1rem);
            }
            .energy-track {
                height: 32px;
                background: rgba(255, 255, 255, 0.03);
                border-radius: 6px;
                position: relative;
                overflow: hidden;
            }
            .energy-fill {
                height: 100%;
                border-radius: 6px;
                width: 0;
                transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
                display: flex;
                align-items: center;
                padding-left: 8px;
            }
            .slide.active .energy-fill {
                width: var(--w);
            }
            .energy-ev {
                font-family: "JetBrains Mono", monospace;
                font-size: clamp(0.7rem, 1vw, 0.85rem);
                color: #9ca3af;
            }
            .energy-type {
                font-size: clamp(0.65rem, 0.9vw, 0.75rem);
                padding: 2px 8px;
                border-radius: 10px;
                display: inline-block;
            }
            .type-noble {
                background: rgba(167, 139, 250, 0.15);
                color: #a78bfa;
            }
            .type-ghg {
                background: rgba(52, 211, 153, 0.15);
                color: #34d399;
            }
            .type-bulk {
                background: rgba(107, 114, 128, 0.15);
                color: #6b7280;
            }

            .threshold-line {
                position: absolute;
                top: 0;
                height: 100%;
                width: 2px;
                background: #f59e0b;
                box-shadow: 0 0 8px rgba(245, 158, 11, 0.4);
                z-index: 10;
                opacity: 0;
                transition:
                    left 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                    opacity 0.3s ease;
            }
            .threshold-label {
                position: absolute;
                top: -22px;
                left: 50%;
                transform: translateX(-50%);
                font-size: 0.7rem;
                font-family: "JetBrains Mono", monospace;
                color: #f59e0b;
                white-space: nowrap;
            }
            .slide.active .threshold-line {
                opacity: 1;
            }

            /* ===== Component: Separation Diagram ===== */
            .separation-svg {
                width: min(700px, 90vw);
                height: 300px;
                margin: 1.5em auto;
                display: block;
            }

            /* ===== Component: Larmor Diagram ===== */
            .larmor-svg {
                width: min(700px, 90vw);
                height: 300px;
                margin: 1.5em auto;
                display: block;
            }

            /* ===== Component: Crowd Scene ===== */
            .crowd-scene {
                position: relative;
                width: min(500px, 80vw);
                height: 200px;
                margin: 1.5em auto;
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 12px;
                background: rgba(255, 255, 255, 0.02);
                overflow: hidden;
            }
            .crowd-dot {
                position: absolute;
                width: 6px;
                height: 6px;
                background: rgba(107, 114, 128, 0.4);
                border-radius: 50%;
            }
            .crowd-ion {
                position: absolute;
                width: 8px;
                height: 8px;
                background: #a78bfa;
                border-radius: 50%;
                box-shadow: 0 0 6px rgba(167, 139, 250, 0.4);
            }

            /* ===== Component: Collection Methods ===== */
            .collection-grid {
                display: grid;
