                font-size: clamp(0.95rem, 1.5vw, 1.2rem);
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }
            .summary-list li::before {
                content: "";
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: rgba(56, 189, 248, 0.1);
                border: 1px solid rgba(56, 189, 248, 0.3);
