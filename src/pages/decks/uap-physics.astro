            .summary-list li::after {
                content: "";
                position: absolute;
                left: 5px;
                top: 50%;
                transform: translateY(-50%) rotate(45deg);
                width: 5px;
                height: 10px;
                border-right: 2px solid #38bdf8;
                border-bottom: 2px solid #38bdf8;
