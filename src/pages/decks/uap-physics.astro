        <script>
            (function () {
                const slides = document.querySelectorAll(".slide");
                const progressBar = document.getElementById("progress-bar");
                const counter = document.getElementById("slide-counter");
                const navHint = document.getElementById("nav-hint");
                let current = 0;
                const total = slides.length;

                function goTo(n) {
                    if (n < 0 || n >= total) return;
                    slides[current].classList.remove("active");
                    current = n;
                    slides[current].classList.add("active");
                    progressBar.style.width =
                        (current / (total - 1)) * 100 + "%";
                    counter.textContent = current + 1 + " / " + total;
                    if (current > 0) navHint.style.opacity = "0";
                }

                function next() {
                    goTo(current + 1);
                }
                function prev() {
                    goTo(current - 1);
                }

                // Keyboard
                document.addEventListener("keydown", function (e) {
                    if (e.target.tagName === "INPUT") return;
                    if (
                        e.key === "ArrowRight" ||
                        e.key === " " ||
                        e.key === "PageDown"
                    ) {
                        e.preventDefault();
                        next();
                    } else if (e.key === "ArrowLeft" || e.key === "PageUp") {
                        e.preventDefault();
                        prev();
                    } else if (e.key === "Home") {
                        e.preventDefault();
                        goTo(0);
                    } else if (e.key === "End") {
                        e.preventDefault();
                        goTo(total - 1);
                    }
                });

                // Click: left third = prev, rest = next
                document.addEventListener("click", function (e) {
                    if (e.target.closest(".calc-grid")) return;
                    if (e.clientX < window.innerWidth * 0.25) {
                        prev();
                    } else {
                        next();
                    }
                });

                // Touch swipe
                let touchStartX = 0;
                document.addEventListener("touchstart", function (e) {
                    if (e.target.closest(".calc-grid")) return;
                    touchStartX = e.changedTouches[0].screenX;
                });
                document.addEventListener("touchend", function (e) {
                    if (e.target.closest(".calc-grid")) return;
                    const diff = touchStartX - e.changedTouches[0].screenX;
                    if (Math.abs(diff) > 50) {
                        if (diff > 0) next();
                        else prev();
                    }
                });

                // Init
                goTo(0);

                // Economics calculator
                var calcSliders = document.querySelectorAll(".calc-range");
                if (calcSliders.length) {
                    var AR_KG = 12.8;
                    var NE_KG = 0.0036;
                    var KR_KG = 0.0033;
                    var XE_KG = 0.000394;
                    var CO2_T = 0.00064;

                    function fmtDollar(n) {
                        if (Math.abs(n) >= 1000)
                            return (
                                "$" +
                                n.toLocaleString("en-US", {
                                    maximumFractionDigits: 0,
                                })
                            );
                        if (Math.abs(n) >= 100) return "$" + n.toFixed(0);
                        if (Math.abs(n) >= 1) return "$" + n.toFixed(2);
                        return "$" + n.toFixed(3);
                    }

                    function updateCalc() {
                        var elecCost = parseFloat(
                            document.getElementById("elec-cost").value,
                        );
                        var energyTonne = parseFloat(
                            document.getElementById("energy-tonne").value,
                        );
                        var eff =
                            parseFloat(
                                document.getElementById("efficiency").value,
                            ) / 100;
                        var arPrice = parseFloat(
                            document.getElementById("ar-price").value,
                        );
                        var nePrice = parseFloat(
                            document.getElementById("ne-price").value,
                        );
                        var krPrice = parseFloat(
                            document.getElementById("kr-price").value,
                        );
                        var xePrice = parseFloat(
                            document.getElementById("xe-price").value,
                        );
                        var co2Price = parseFloat(
                            document.getElementById("co2-price").value,
                        );
                        var omCost = parseFloat(
                            document.getElementById("om-cost").value,
                        );
                        var storageCost = parseFloat(
                            document.getElementById("storage-cost").value,
                        );

                        document.getElementById("val-elec-cost").textContent =
                            "$" + elecCost.toFixed(2) + "/kWh";
                        document.getElementById(
                            "val-energy-tonne",
                        ).textContent = energyTonne + " kWh";
                        document.getElementById("val-efficiency").textContent =
                            (eff * 100).toFixed(0) + "%";
                        document.getElementById("val-ar-price").textContent =
                            "$" + arPrice.toFixed(2) + "/kg";
                        document.getElementById("val-ne-price").textContent =
                            "$" + nePrice.toFixed(0) + "/kg";
                        document.getElementById("val-kr-price").textContent =
                            "$" + krPrice.toLocaleString("en-US") + "/kg";
                        document.getElementById("val-xe-price").textContent =
                            "$" + xePrice.toLocaleString("en-US") + "/kg";
                        document.getElementById("val-co2-price").textContent =
                            "$" + co2Price + "/t CO\u2082";
                        document.getElementById("val-om-cost").textContent =
                            "$" + omCost + "/t";
                        document.getElementById(
                            "val-storage-cost",
                        ).textContent = "$" + storageCost + "/t";

                        var energyCost = energyTonne * elecCost;
                        var cost = energyCost + omCost + storageCost;
                        var arYield = AR_KG * eff;
                        var neYield = NE_KG * eff;
                        var krYield = KR_KG * eff;
                        var xeYield = XE_KG * eff;
                        var co2Yield = CO2_T * eff;

                        var arRev = arYield * arPrice;
                        var neRev = neYield * nePrice;
                        var krRev = krYield * krPrice;
                        var xeRev = xeYield * xePrice;
                        var co2Rev = co2Yield * co2Price;
                        var totalRev = arRev + neRev + krRev + xeRev + co2Rev;
                        var net = totalRev - cost;

                        document.getElementById("yield-ar").textContent =
                            arYield.toFixed(2) + " kg";
                        document.getElementById("yield-ne").textContent =
                            (neYield * 1000).toFixed(2) + " g";
                        document.getElementById("yield-kr").textContent =
                            (krYield * 1000).toFixed(2) + " g";
                        document.getElementById("yield-xe").textContent =
                            (xeYield * 1000).toFixed(2) + " g";
                        document.getElementById("yield-co2").textContent =
                            (co2Yield * 1000).toFixed(2) + " kg";

                        document.getElementById("rev-ar").textContent =
                            fmtDollar(arRev);
                        document.getElementById("rev-ne").textContent =
                            fmtDollar(neRev);
                        document.getElementById("rev-kr").textContent =
                            fmtDollar(krRev);
                        document.getElementById("rev-xe").textContent =
                            fmtDollar(xeRev);
                        document.getElementById("rev-co2").textContent =
                            fmtDollar(co2Rev);

                        document.getElementById("cost-energy").textContent =
                            "\u2212" + fmtDollar(energyCost);
                        document.getElementById("cost-om").textContent =
                            "\u2212" + fmtDollar(omCost);
                        document.getElementById("cost-storage").textContent =
                            "\u2212" + fmtDollar(storageCost);
                        document.getElementById("total-cost").textContent =
                            "\u2212" + fmtDollar(cost);
                        document.getElementById("total-rev").textContent =
                            fmtDollar(totalRev);

                        var netEl = document.getElementById("net-display");
                        var sign = net >= 0 ? "+" : "\u2212";
                        netEl.textContent =
                            sign + fmtDollar(Math.abs(net)) + " / tonne";
                        netEl.className =
                            "calc-net-value " + (net >= 0 ? "profit" : "loss");
                    }

                    calcSliders.forEach(function (s) {
                        s.addEventListener("input", updateCalc);
                    });
                    updateCalc();
                }
            })();
        </script>
    </body>
</html>
